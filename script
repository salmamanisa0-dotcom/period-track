function hitungPrediksi(){

    let tanggal =
    document.getElementById("tanggalMulai").value;

    if(tanggal==""){
        alert("Pilih tanggal terlebih dahulu");
        return;
    }

    let mulai = new Date(tanggal);

    let haid = new Date(mulai);
    haid.setDate(haid.getDate()+28);

    let subur = new Date(mulai);
    subur.setDate(subur.getDate()+14);

    let ovulasi = new Date(mulai);
    ovulasi.setDate(ovulasi.getDate()+14);

    document.getElementById("prediksiHaid")
    .innerHTML =
    haid.toLocaleDateString("id-ID");

    document.getElementById("masaSubur")
    .innerHTML =
    subur.toLocaleDateString("id-ID");

    document.getElementById("ovulasi")
    .innerHTML =
    ovulasi.toLocaleDateString("id-ID");

    localStorage.setItem(
        "tanggalMulai",
        tanggal
    );

    // SIMPAN KE RIWAYAT

    let riwayat =
    JSON.parse(
        localStorage.getItem("riwayat")
    ) || [];

    riwayat.push(tanggal);

    console.log(riwayat);

    localStorage.setItem(
        "riwayat",
        JSON.stringify(riwayat)
    );

    let eventKalender = [];

    eventKalender.push({

        title: "🩸 Hari Pertama Haid",

        start: tanggal,

        color: "#ff4d88"

    });

    eventKalender.push({

        title: "🌱 Masa Subur",

        start: subur.toISOString().split("T")[0],

        color: "#28a745"

    });

    eventKalender.push({

        title: "🥚 Ovulasi",

        start: ovulasi.toISOString().split("T")[0],

        color: "#ffc107"

    });

    localStorage.setItem(
        "eventKalender",
        JSON.stringify(eventKalender)
    );

    tampilkanRiwayat();
    tampilkanStatistik();
    tampilkanRingkasan();

    location.reload();
}

function simpanGejala(){

    let mood =
    document.getElementById("mood").value;

    let nyeri =
    document.getElementById("nyeri").value;

    let catatan =
    document.getElementById("catatan").value;

    let data = {

        mood: mood,
        nyeri: nyeri,
        catatan: catatan

    };

    localStorage.setItem(
        "gejala",
        JSON.stringify(data)
    );

    tampilkanGejala();

    alert("Catatan berhasil disimpan");
}

function tampilkanGejala(){

    let data =
    JSON.parse(
        localStorage.getItem("gejala")
    );

    if(!data) return;

    document.getElementById("hasilGejala")
    .innerHTML = `

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <h5>📋 Catatan Terakhir</h5>

            <p><b>Mood:</b> ${data.mood}</p>

            <p><b>Nyeri:</b> ${data.nyeri}</p>

            <p><b>Catatan:</b> ${data.catatan}</p>

        </div>

    </div>

    `;
}

tampilkanGejala();

function tampilkanRiwayat(){

    let riwayat =
    JSON.parse(
        localStorage.getItem("riwayat")
    ) || [];

    let html = "";

    if(riwayat.length === 0){

        html = `
            <p class="text-muted">
                Belum ada data.
            </p>
        `;

    }else{

        riwayat.forEach((item,index)=>{

            html += `
            <div class="card mt-2">

                <div class="card-body">

                    <b>Siklus ${index+1}</b>

                    <br>

                    ${item}

                </div>

            </div>
            `;

        });

    }

    document.getElementById("riwayatSiklus").innerHTML = html;
}

