function muatPrediksiTerakhir(){

        let tanggal =
        localStorage.getItem("tanggalMulai");

        if(!tanggal) return;

        let mulai = new Date(tanggal);

        let haid = new Date(mulai);
        haid.setDate(haid.getDate()+28);

        let subur = new Date(mulai);
        subur.setDate(subur.getDate()+14);

        let ovulasi = new Date(mulai);
        ovulasi.setDate(ovulasi.getDate()+14);

        document.getElementById("prediksiHaid")
        .innerHTML =
        haid.toLocaleDateString("id-ID");

        document.getElementById("masaSubur")
        .innerHTML =
        subur.toLocaleDateString("id-ID");

        document.getElementById("ovulasi")
        .innerHTML =
        ovulasi.toLocaleDateString("id-ID");

        let hariIni = new Date();

        hariIni.setHours(0,0,0,0);
        haid.setHours(0,0,0,0);

        let selisih =
        Math.ceil(
            (haid - hariIni) /
            (1000 * 60 * 60 * 24)
        );

        let teksCountdown = "";

        if(selisih > 1){

            teksCountdown =
            `⏳ Haid berikutnya diperkirakan ${selisih} hari lagi`;

        }else if(selisih === 1){

            teksCountdown =
            "⏳ Haid berikutnya diperkirakan besok";

        }else if(selisih === 0){

            teksCountdown =
            "⏳ Haid diperkirakan hari ini";

        }else{

            teksCountdown =
            "⏳ Silakan masukkan data baru";

}

document.getElementById(
    "countdownHaid"
).innerHTML = teksCountdown;

}



function toggleDarkMode(){

    document.body.classList.toggle(
        "dark-mode"
    );

    if(
        document.body.classList.contains(
            "dark-mode"
        )
    ){

        localStorage.setItem(
            "darkMode",
            "on"
        );

    }else{

        localStorage.setItem(
            "darkMode",
            "off"
        );

    }

}

function tampilkanStatistik(){

        let riwayat =
        JSON.parse(
            localStorage.getItem("riwayat")
        ) || [];

        document.getElementById(
            "totalSiklus"
        ).innerHTML = riwayat.length;

}

function tampilkanRingkasan(){

    let riwayat =
    JSON.parse(
        localStorage.getItem("riwayat")
    ) || [];

    if(riwayat.length === 0){

        document.getElementById(
            "ringkasanSiklus"
        ).innerHTML =
        "Belum ada data";

        return;

    }

    let terakhir =
    riwayat[riwayat.length - 1];

    document.getElementById(
        "ringkasanSiklus"
    ).innerHTML = `

        <p>
            <b>Siklus terakhir dimulai:</b>
            <br>
            ${terakhir}
        </p>

        <p>
            <b>Total siklus tercatat:</b>
            <br>
            ${riwayat.length}
        </p>

    `;

}

function hapusSemuaData(){

        let yakin = confirm(
            "Yakin ingin menghapus semua data?"
        );

        if(!yakin) return;

        localStorage.clear();

        location.reload();

}

    tampilkanGejala();
    tampilkanRiwayat();
    muatPrediksiTerakhir();
    tampilkanStatistik();
    tampilkanRingkasan();

    if(
        localStorage.getItem(
            "darkMode"
        ) === "on"
    ){

        document.body.classList.add(
            "dark-mode"
     );

    }
